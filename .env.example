# Copia este archivo como .env y reemplaza con tus datos reales de Supabase.
# En Supabase: Project Settings -> API (URL) y API Keys (Secret key para backend).
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_KEY=sb_secret_tu_llave_secreta

# --- Modo OFFLINE (opcional) ---
# Para ejecutar SIN internet usando la base de datos local SQLite, define
# LOCAL_DB (tiene prioridad sobre Supabase):
# LOCAL_DB=data_local/ciudades.db
